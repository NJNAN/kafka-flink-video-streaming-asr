# 真实视频输入。可以是容器内文件路径、RTSP 地址或 HTTP/FLV 地址。
VIDEO_SOURCE=/videos/input.mp4

# 每一路视频的唯一 ID，会写入 Kafka 消息和 Redis。
STREAM_ID=demo-video

# 固定切片长度，只有 INGEST_SEGMENT_MODE=fixed 时才使用。
SEGMENT_SECONDS=6

# 推荐使用 VAD 动态切块。这样会按语音停顿切句，而不是机械地每 N 秒切一次。
INGEST_SEGMENT_MODE=vad
INGEST_VAD_FRAME_MS=30
INGEST_VAD_AGGRESSIVENESS=2
INGEST_VAD_MIN_CHUNK_MS=500
INGEST_VAD_TARGET_CHUNK_MS=3000
INGEST_VAD_HARD_MAX_CHUNK_MS=4500
INGEST_VAD_MAX_SILENCE_MS=1400
INGEST_VAD_SHORT_BOUNDARY_MS=240
INGEST_VAD_PADDING_MS=300

# 本地 ASR 模型配置。RTX 4060 追求准确率建议 large-v3 + cuda + float16。
# 如果显存或速度压力大，可以降级：ASR_COMPUTE_TYPE=int8_float16 或 ASR_MODEL=medium。
ASR_MODEL=large-v3
ASR_MODEL_PATH=
HF_HUB_DISABLE_XET=1
HF_HUB_ENABLE_HF_TRANSFER=1
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_LANGUAGE=zh
ASR_PRELOAD=true
ASR_SIMPLIFIED_CHINESE=true
ASR_BEAM_SIZE=5
ASR_BEST_OF=5
ASR_CONTEXT_CHARS=60
ASR_USE_CONTEXT=false
ASR_ENABLE_VAD=true
ASR_ENABLE_ENERGY_FILTER=true
ASR_ENERGY_THRESHOLD_DBFS=-42
ASR_CONDITION_ON_PREVIOUS_TEXT=false
ASR_REPETITION_PENALTY=1.05
ASR_NO_REPEAT_NGRAM_SIZE=3
ASR_COMPRESSION_RATIO_THRESHOLD=2.2
ASR_LOG_PROB_THRESHOLD=-1.0
ASR_NO_SPEECH_THRESHOLD=0.6
ASR_SKIP_NO_SPEECH_PROB=0.65
ASR_SKIP_AVG_LOGPROB_BELOW=-0.85
ASR_HALLUCINATION_SILENCE_THRESHOLD=1.0
ASR_FILTER_REPETITION=true
ASR_HALLUCINATION_PATTERNS=请不吝点赞|点赞订阅|订阅转发|打赏支持|感谢观看|请逐字准确转写真实语音|不要总结|不要重复无声内容
ASR_INITIAL_PROMPT=普通话中文音频，输出简体中文字幕。
ASR_HOTWORDS=
ASR_MAX_HOTWORDS=120
ASR_SUBTITLE_SKIP_NO_SPEECH_PROB=0.88
ASR_SUBTITLE_SKIP_AVG_LOGPROB_BELOW=-1.20
ASR_VAD_MIN_SILENCE_MS=300

# Kafka Topic。
AUDIO_TOPIC=audio-segment
TRANSCRIPT_TOPIC=transcription-result
KEYWORD_TOPIC=keyword-event
HOTWORD_UPDATE_TOPIC=streamsense.hotword.updates
FLINK_JOB_PARALLELISM=1

# 动态热词发现。默认由系统从真实转写结果里累计，不再依赖静态热词表。
HOTWORD_AUTO_DISCOVERY_ENABLED=true
HOTWORD_DISCOVERY_TOP_K=30
HOTWORD_AUTO_ADD_MIN_COUNT=5
HOTWORD_MAX_WORDS=120
HOTWORD_MIN_TRANSCRIPT_LOGPROB=-0.55
HOTWORD_USE_STATIC_HINTS=false
HOTWORD_RECENT_WINDOW_MS=300000
HOTWORD_RECENT_WINDOW_SEGMENTS=120

# 句子级输出。ASR 仍按短音频切片推理，但 Dashboard 和关键词分析按自然句展示。
SENTENCE_BUFFER_ENABLED=true
SENTENCE_MAX_CHARS=110
SENTENCE_FLUSH_GAP_MS=1500
SENTENCE_STALE_FLUSH_MS=3000
SENTENCE_ADD_PERIOD_ON_FLUSH=true
SENTENCE_DROP_INCOMPLETE_ON_FLUSH=false
SENTENCE_MARK_INCOMPLETE_ON_FLUSH=true
SENTENCE_INCOMPLETE_ENDINGS=因为|所以|但是|然而|并且|以及|如果|虽然|或者|并不是|换句话说|比如|例如|首先|其次
